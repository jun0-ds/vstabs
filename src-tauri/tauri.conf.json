{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vstabs",
  "version": "0.1.0",
  "identifier": "com.vstabs.app",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "vstabs",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "L1 project tab bar for desktop VS Code",
    "longDescription": "vstabs collapses N project VS Code windows into one container with an always-visible tab bar. Local, WSL, and SSH backends unified."
  }
}
